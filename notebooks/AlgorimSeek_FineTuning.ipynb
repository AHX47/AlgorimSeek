    mid: int
begin
    low  <--- 0
    high <--- n - 1
    binary_search <--- -1
    while (low <= high) do
        mid <--- (low + high) div 2
        if (T[mid] = target) then
            binary_search <--- mid
            low <--- high + 1
        else
            if (T[mid] < target) then
                low <--- mid + 1
            else
                high <--- mid - 1
            endif
        endif
    done
end""")
